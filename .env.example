# ─── Clerk (Auth) ────────────────────────────────────────────────────────────
# Frontend-safe: exposed to the browser via VITE_ prefix
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Server-side only: NEVER prefix with VITE_
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# ─── Neon (Database) ─────────────────────────────────────────────────────────
# Server-side only: used by API routes / serverless functions
DATABASE_URL=postgresql://user:password@ep-REPLACE.us-east-2.aws.neon.tech/shopcommand?sslmode=require

# ─── Stripe (Payments) ──────────────────────────────────────────────────────
# Frontend-safe: exposed to the browser via VITE_ prefix
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Server-side only
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ─── Vercel Blob (File Uploads) ─────────────────────────────────────────────
# Server-side only: auto-generated when you create a Blob store in Vercel
BLOB_READ_WRITE_TOKEN=vercel_blob_REPLACE_ME

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# Optional: override defaults (requests per window)
# RATE_LIMIT_GENERAL=100
# RATE_LIMIT_AUTH=5
# RATE_LIMIT_WINDOW_MS=900000
